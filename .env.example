# Application Configuration
APP_NAME=BlockchainComplianceMonitor
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Database
POSTGRES_PASSWORD=change_me_strong_random_password
DATABASE_URL=postgresql://compliance_user:${POSTGRES_PASSWORD}@localhost:5432/compliance_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis Cache
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Security — REQUIRED: startup will fail if these are missing or placeholder values
SECRET_KEY=replace_with_64_char_hex_openssl_rand_hex_32
JWT_SECRET_KEY=replace_with_64_char_hex_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption — REQUIRED
ENCRYPTION_KEY=replace_with_32_byte_random_key
DATA_ENCRYPTION_ENABLED=true

# Regulatory Configuration
ENABLED_JURISDICTIONS=US,EU,APAC
DEFAULT_JURISDICTION=US

# US Regulations
BSA_REPORTING_ENABLED=true
FINCEN_API_KEY=your-fincen-api-key
FINCEN_INSTITUTION_ID=your-institution-id
OFAC_SCREENING_ENABLED=true
OFAC_API_KEY=your-ofac-api-key
OFAC_REFRESH_INTERVAL_HOURS=24

# EU Regulations
MICA_COMPLIANCE_ENABLED=true
EU_SANCTIONS_ENABLED=true
EU_SANCTIONS_REFRESH_INTERVAL_HOURS=24
GDPR_COMPLIANCE_MODE=strict

# Asia-Pacific
FATF_COMPLIANCE_ENABLED=true
APAC_REGIONAL_CHECKS=HK,SG,JP

# Sanctions Screening
UN_SANCTIONS_ENABLED=true
SANCTIONS_CACHE_ENABLED=true
SANCTIONS_CACHE_TTL_HOURS=12

# Risk Engine
RISK_SCORING_ENABLED=true
DEFAULT_RISK_THRESHOLD=70
HIGH_RISK_THRESHOLD=85
ML_MODEL_ENABLED=false
ML_MODEL_PATH=models/risk_scorer_v1.pkl

# Transaction Monitoring
MONITORING_ENABLED=true
TRANSACTION_QUEUE_SIZE=10000
ALERT_THRESHOLD_USD=10000
SUSPICIOUS_PATTERN_DETECTION=true
BEHAVIORAL_ANALYSIS_ENABLED=true

# Smart Contract Validation
CONTRACT_VALIDATION_ENABLED=true
SOLIDITY_COMPILER_VERSION=0.8.20
VYPER_COMPILER_VERSION=0.3.10
AUTO_VALIDATION_ON_DEPLOY=true

# Blockchain Connections
ETH_RPC_URL=https://eth-mainnet.alchemyapi.io/v2/your-api-key
ETH_ARCHIVE_NODE=false
BSC_RPC_URL=https://bsc-dataseed.binance.org/
POLYGON_RPC_URL=https://polygon-rpc.com/
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# External Compliance APIs
CHAINALYSIS_API_KEY=your-chainalysis-api-key
CHAINALYSIS_API_URL=https://api.chainalysis.com
ELLIPTIC_API_KEY=your-elliptic-api-key
ELLIPTIC_API_URL=https://api.elliptic.co
TRM_LABS_API_KEY=your-trm-labs-api-key
TRM_LABS_API_URL=https://api.trmlabs.com

# SWIFT Integration
SWIFT_INTEGRATION_ENABLED=false
SWIFT_API_URL=https://api.swift.com
SWIFT_INSTITUTION_BIC=YOURBICODE
SWIFT_API_KEY=your-swift-api-key
SWIFT_CERTIFICATE_PATH=/path/to/swift/cert.pem

# ISO 20022 Messaging
ISO20022_ENABLED=true
ISO20022_MESSAGE_VERSION=2019
ISO20022_SCHEMA_PATH=schemas/iso20022/

# Banking System Integration
BANKING_API_ENABLED=false
BANKING_API_URL=https://banking-api.example.com
BANKING_API_KEY=your-banking-api-key
BANKING_API_CERT_PATH=/path/to/banking/cert.pem

# Reporting
AUTO_REPORTING_ENABLED=true
REPORT_GENERATION_SCHEDULE=0 0 * * *
REPORT_RETENTION_DAYS=2555
REPORT_EXPORT_FORMATS=PDF,XML,JSON

# Audit Trail
AUDIT_TRAIL_ENABLED=true
AUDIT_IMMUTABILITY_CHECK=true
AUDIT_BLOCKCHAIN_ANCHORING=false
AUDIT_BLOCKCHAIN_NETWORK=ethereum
AUDIT_SMART_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Notifications
NOTIFICATIONS_ENABLED=true
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=compliance@globalsettlement.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
PAGERDUTY_API_KEY=your-pagerduty-api-key

# Monitoring & Observability
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=true
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development

# API Authentication
# Leave empty to disable auth check (dev only). Set a strong random value in production.
COMPLIANCE_API_KEY=replace_with_strong_random_api_key

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Data Retention
DATA_RETENTION_DAYS=2555
PII_RETENTION_DAYS=2555
LOG_RETENTION_DAYS=365
CACHE_CLEANUP_INTERVAL_HOURS=24

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=90
BACKUP_STORAGE_PATH=/backups

# Feature Flags
FEATURE_ML_RISK_SCORING=false
FEATURE_ADVANCED_ANALYTICS=false
FEATURE_DEFI_MONITORING=false
FEATURE_NFT_COMPLIANCE=false
FEATURE_STABLECOIN_MONITORING=true
FEATURE_CROSS_CHAIN_TRACKING=false
